# =============================================================================
# Enterprise Architectural Intelligence System — Environment Variables
# Copy this file to .env and adjust values as needed:
#   cp .env.template .env
# =============================================================================

# ---- AWS Mock Credentials (LocalStack) ----
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT_URL=http://localstack:4566
AWS_ENDPOINT_URL_EXTERNAL=http://localhost:4566

# ---- LocalStack Configuration ----
LOCALSTACK_HOST=localstack
LOCALSTACK_PORT=4566
SERVICES=s3,sqs,stepfunctions,iam
LOCALSTACK_ACKNOWLEDGE_ACCOUNT_REQUIREMENT=1

# ---- S3 Bucket ----
S3_BUCKET_NAME=arch-ingestion-bucket

# ---- SQS Queue Names ----
SQS_RASTER_QUEUE=Raster-Processing-Queue
SQS_VECTOR_QUEUE=Vector-Processing-Queue

# ---- Step Functions ----
STATE_MACHINE_NAME=architectural-plan-processor

# ---- Qdrant Vector Database ----
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_URI=http://qdrant:6333
QDRANT_API_KEY=

# ---- Java Spring Boot (Dimension Audit Engine) ----
JAVA_SERVICE_PORT=8080
SPRING_PROFILES_ACTIVE=local

# ---- Python Microservice Ports ----
FILE_INGESTION_PORT=8001
RASTER_LINE_EXTRACTION_PORT=8002
DXF_GEOMETRY_EXTRACTION_PORT=8003
GRAPH_EXPORT_PORT=8004
COMPLIANCE_CHECKER_PORT=8005

# ---- LangGraph / OpenAI (for compliance-checker) ----
OPENAI_API_KEY=sk-placeholder
LANGCHAIN_TRACING_V2=false

# ---- General ----
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1