# =============================================================================
# Dockerfile.python.langgraph — Specialized Python image for the Compliance
# Checker service (LangGraph agents + Qdrant client)
# =============================================================================
# Build context: project root
#   docker build -f docker/Dockerfile.python.langgraph -t compliance-checker:latest .
# =============================================================================

FROM python:3.12-slim AS base

LABEL maintainer="ArchIntel DevOps"
LABEL description="Compliance Checker — LangGraph Agent with Qdrant vector store"
LABEL version="1.0.0"

ARG SERVICE_DIR=services/compliance-checker
ARG SERVICE_PORT=8005

# Service port available at runtime
ENV SERVICE_PORT=${SERVICE_PORT}

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# Install system dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        curl \
        build-essential \
        gcc \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN groupadd -r appgroup && useradd -r -g appgroup -d /app -s /sbin/nologin appuser

WORKDIR /app

# ---------------------------------------------------------------------------
# Install Python dependencies
# ---------------------------------------------------------------------------
COPY ${SERVICE_DIR}/requirements.txt ./requirements.txt

RUN pip install --no-cache-dir fastapi>=0.115.0 uvicorn[standard]>=0.32.0 && \
    pip install --no-cache-dir -r requirements.txt

# ---------------------------------------------------------------------------
# Copy service source code
# ---------------------------------------------------------------------------
COPY ${SERVICE_DIR} .

# Fix ownership
RUN chown -R appuser:appgroup /app

USER appuser

EXPOSE ${SERVICE_PORT}

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
  CMD curl -f http://localhost:${SERVICE_PORT}/health || exit 1

# Default entrypoint — FastAPI server for HTTP health check and API
CMD ["python", "server.py"]
